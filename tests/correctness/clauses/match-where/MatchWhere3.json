      "description": "[1] Join between node identities",
      "setup": [
        "CREATE (:A), (:B)"
      ],
      "query": "MATCH (a), (b)\nWHERE a = b\nRETURN a, b",
      "expect_columns": [
        "a",
        "b"
      ],
      "expect_rows": [
        [
          "(:A)",
          "(:A)"
        ],
        [
          "(:B)",
          "(:B)"
        ]
      ],
