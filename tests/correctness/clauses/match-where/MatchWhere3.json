      "description": "[2] Join between node properties of disconnected nodes",
      "setup": [
        "CREATE (:A {id: 1}), (:A {id: 2}), (:B {id: 2}), (:B {id: 3})"
      ],
      "query": "MATCH (a:A), (b:B)\nWHERE a.id = b.id\nRETURN a, b",
      "expect_columns": [
        "a",
        "b"
