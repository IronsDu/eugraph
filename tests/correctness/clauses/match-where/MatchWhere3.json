    {
      "id": "MatchWhere3 - Equi-Joins on variables-[3] Join between node properties of adjacent nodes",
      "description": "[3] Join between node properties of adjacent nodes",
      "setup": [
        "CREATE (a:A {animal: 'monkey'}), (b:B {animal: 'cow'}), (c:C {animal: 'monkey'}), (d:D {animal: 'cow'}), (a)-[:KNOWS]->(b), (a)-[:KNOWS]->(c), (d)-[:KNOWS]->(b), (d)-[:KNOWS]->(c)"
      ],
      "query": "MATCH (n)-[rel]->(x)\nWHERE n.animal = x.animal\nRETURN n, x",
      "expect_columns": [
        "n",
        "x"
      ],
      "expect_rows": [
        [
          "(:A {animal: 'monkey'})",
