      "id": "Match4 - Match variable length patterns scenarios-[4] Matching longer variable length paths",
      "description": "[4] Matching longer variable length paths",
      "setup": [
        "CREATE (a {var: 'start'}), (b {var: 'end'})",
        "WITH *",
        "UNWIND range(1, 20) AS i",
        "CREATE (n {var: i})",
        "WITH a, b, [a] + collect(n) + [b] AS nodeList",
        "UNWIND range(0, size(nodeList) - 2, 1) AS i",
        "WITH nodeList[i] AS n1, nodeList[i+1] AS n2",
        "CREATE (n1)-[:T]->(n2)"
      ],
      "query": "MATCH (n {var: 'start'})-[:T*]->(m {var: 'end'})\nRETURN m",
      "expect_columns": [
