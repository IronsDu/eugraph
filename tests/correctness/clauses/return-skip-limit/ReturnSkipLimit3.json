  "feature": "ReturnSkipLimit3 - Skip and limit",
  "capability": "partial",
  "scenarios": [
    {
      "id": "ReturnSkipLimit3 - Skip and limit-[1] Get rows in the middle",
      "description": "[1] Get rows in the middle",
      "setup": [
        "CREATE ({name: 'A'}), ({name: 'B'}), ({name: 'C'}), ({name: 'D'}), ({name: 'E'})"
      ],
      "query": "MATCH (n)\nRETURN n\nORDER BY n.name ASC\nSKIP 2\nLIMIT 2",
      "expect_columns": [
        "n"
      ],
      "expect_rows": [
        [
          "({name: 'C'})"
        ],
        [
          "({name: 'D'})"
        ]
      ],
      "ordered": true,
      "requires": [
        "LIMIT",
        "ORDER BY",
        "SKIP"
      ],
      "tags": [],
      "note": "partial: may need manual adjustment"
    },
