    {
      "id": "Return4 - Column renaming-[11] Reusing variable names in RETURN",
      "description": "[11] Reusing variable names in RETURN",
      "setup": [
        "CREATE (a:Person), (b:Person), (m:Message {id: 10})",
        "CREATE (a)-[:LIKE {creationDate: 20160614}]->(m)-[:POSTED_BY]->(b)"
      ],
      "query": "MATCH (person:Person)<--(message)<-[like]-(:Person)\nWITH like.creationDate AS likeTime, person AS person\n  ORDER BY likeTime, message.id\nWITH head(collect({likeTime: likeTime})) AS latestLike, person AS person\nRETURN latestLike.likeTime AS likeTime\n  ORDER BY likeTime",
      "expect_columns": [
        "likeTime"
      ],
      "expect_rows": [
        [
          "20160614"
        ]
      ],
      "ordered": true,
      "requires": [
        "ORDER BY",
        "collect"
      ],
      "tags": [],
      "note": "partial: may need manual adjustment"
