    {
      "id": "Return4 - Column renaming-[9] Handle subexpression in aggregation also occurring as standalone expression with nested aggregation in a literal map",
      "description": "[9] Handle subexpression in aggregation also occurring as standalone expression with nested aggregation in a literal map",
      "setup": [
        "CREATE (:A), (:B {num: 42})"
      ],
      "query": "MATCH (a:A), (b:B)\nRETURN coalesce(a.num, b.num) AS foo,\n  b.num AS bar,\n  {name: count(b)} AS baz",
      "expect_columns": [
        "foo",
        "bar",
        "baz"
      ],
      "expect_rows": [
        [
          "42",
          "42",
          "{name: 1}"
        ]
      ],
      "ordered": false,
      "requires": [
        "coalesce"
      ],
