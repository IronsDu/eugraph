{
  "source": "clauses/return/Return4.feature",
  "source_version": "openCypher TCK (Apache 2.0)",
  "feature": "Return4 - Column renaming",
  "capability": "partial",
  "scenarios": [
    {
      "id": "Return4 - Column renaming-[1] Honour the column name for RETURN items",
      "description": "[1] Honour the column name for RETURN items",
      "setup": [
        "CREATE ({name: 'Someone'})"
      ],
      "query": "MATCH (a)\nWITH a.name AS a\nRETURN a",
      "expect_columns": [
        "a"
      ],
      "expect_rows": [
        [
          "'Someone'"
        ]
      ],
      "ordered": false,
      "requires": [],
      "tags": [],
      "note": "partial: may need manual adjustment"
    },
    {
      "id": "Return4 - Column renaming-[2] Support column renaming",
      "description": "[2] Support column renaming",
      "setup": [
        "CREATE (:Singleton)"
      ],
      "query": "MATCH (a)\nRETURN a AS ColumnName",
      "expect_columns": [
        "ColumnName"
      ],
      "expect_rows": [
        [
          "(:Singleton)"
        ]
      ],
      "ordered": false,
      "requires": [],
      "tags": [],
      "note": "partial: may need manual adjustment"
    },
