  "feature": "Return5 - Implicit grouping with distinct",
  "capability": "partial",
  "scenarios": [
    {
      "id": "Return5 - Implicit grouping with distinct-[1] DISTINCT inside aggregation should work with lists in maps",
      "description": "[1] DISTINCT inside aggregation should work with lists in maps",
      "setup": [
        "CREATE ({list: ['A', 'B']}), ({list: ['A', 'B']})"
      ],
      "query": "MATCH (n)\nRETURN count(DISTINCT {name: n.list}) AS count",
      "expect_columns": [
        "count"
      ],
      "expect_rows": [
        [
          "1"
        ]
      ],
      "ordered": false,
      "requires": [
        "DISTINCT"
      ],
      "tags": [],
      "note": "partial: may need manual adjustment",
      "skip_reason": "catalog: labels must be pre-registered"
    },
