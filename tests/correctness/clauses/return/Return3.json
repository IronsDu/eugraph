    {
      "id": "Return3 - Return multiple expressions (if column order correct)-[3] Projecting nodes and relationships",
      "description": "[3] Projecting nodes and relationships",
      "setup": [
        "CREATE (a:A), (b:B)",
        "CREATE (a)-[:T]->(b)"
      ],
      "query": "MATCH (a)-[r]->()\nRETURN a AS foo, r AS bar",
      "expect_columns": [
        "foo",
        "bar"
      ],
      "expect_rows": [
        [
          "(:A)",
          "[:T]"
        ]
      ],
