    {
      "id": "Pattern2 - Pattern Comprehension-[7] Use a pattern comprehension inside a list comprehension",
      "description": "[7] Use a pattern comprehension inside a list comprehension",
      "setup": [
        "CREATE (n1:X {n: 1}), (m1:Y), (i1:Y), (i2:Y)",
        "CREATE (n1)-[:T]->(m1), (m1)-[:T]->(i1), (m1)-[:T]->(i2)",
        "CREATE (n2:X {n: 2}), (m2), (i3:L), (i4:Y)",
        "CREATE (n2)-[:T]->(m2), (m2)-[:T]->(i3), (m2)-[:T]->(i4)"
      ],
      "query": "MATCH p = (n:X)-->()\nRETURN n, [x IN nodes(p) | size([(x)-->(:Y) | 1])] AS list",
      "expect_columns": [
        "n",
        "list"
      ],
      "expect_rows": [
        [
          "(:X {n: 1})",
          "[1, 2]"
        ],
        [
          "(:X {n: 2})",
          "[0, 1]"
        ]
      ],
      "ordered": false,
      "requires": [
        "IN",
        "nodes"
      ],
      "tags": [],
      "note": "partial: may need manual adjustment"
    },
