      "id": "Pattern2 - Pattern Comprehension-[1] Return a pattern comprehension",
      "description": "[1] Return a pattern comprehension",
      "setup": [
        "CREATE (a:A), (b:B)",
        "CREATE (a)-[:T]->(b), (b)-[:T]->(:C)"
      ],
      "query": "MATCH (n)\nRETURN [p = (n)-->() | p] AS list",
      "expect_columns": [
        "list"
      ],
      "expect_rows": [
        [
          "[<(:A)-[:T]->(:B)>]"
        ],
        [
          "[<(:B)-[:T]->(:C)>]"
        ],
        [
          "[]"
        ]
      ],
      "ordered": false,
      "requires": [],
      "tags": [],
      "note": "partial: may need manual adjustment"
