      "id": "Precedence3 - On list values-[1] List element access takes precedence over list appending",
      "description": "[1] List element access takes precedence over list appending",
      "setup": [],
      "query": "RETURN [[1], [2, 3], [4, 5]] + [5, [6, 7], [8, 9], 10][3] AS a,\n       [[1], [2, 3], [4, 5]] + ([5, [6, 7], [8, 9], 10][3]) AS b,\n       ([[1], [2, 3], [4, 5]] + [5, [6, 7], [8, 9], 10])[3] AS c",
      "expect_columns": [
        "a",
        "b",
        "c"
      ],
      "expect_rows": [
        [
          "[[1], [2, 3], [4, 5], 10]",
          "[[1], [2, 3], [4, 5], 10]",
          "5"
        ]
      ],
      "ordered": false,
      "requires": [],
      "tags": [],
      "skip_reason": "engine: standalone RETURN not supported"
    },
